# The YouTube channel ID you want to monitor for new uploads.
# Format: UCxxxxxxxxxxxxxxxxxxxxxxxxxx  (always starts with UC)
# How to find it: go to the channel page → View Source → search for "channelId"
# Or use: https://commentpicker.com/youtube-channel-id.php
TARGET_CHANNEL_ID=

# Path to the JSON file containing comment templates (relative to project root).
# In simulation mode this file holds static strings (e.g. ["First!"]).
# For live-run mode, replace with dynamic templates using {video_title} and {timestamp}.
COMMENT_TEMPLATES_JSON=config/templates.json

# Path to your Google OAuth client secrets file (relative to project root).
# Download this from: Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client ID → Download JSON
# Rename the downloaded file to client_secrets.json and place it in the credentials/ folder.
GOOGLE_CLIENT_SECRETS_FILE=credentials/client_secrets.json
